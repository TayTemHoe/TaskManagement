{
  "realm": "internship-task-realm",
  "enabled": true,
  "displayName": "Internship Task Realm",
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 1800,
  "ssoSessionIdleTimeout": 1800,
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,

  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Full access — can create, view, update and delete any task"
      },
      {
        "name": "USER",
        "description": "Standard access — can create and view all tasks, update/delete only own tasks"
      }
    ]
  },

  "clients": [
    {
      "clientId": "task-frontend",
      "name": "Task Management React Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://task-frontend:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://task-frontend:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect"
    },
    {
      "clientId": "task-backend",
      "name": "Task Management Spring Boot Backend",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],

  "users": [
    {
      "username": "admin1",
      "email": "admin1@internship.com",
      "firstName": "Admin",
      "lastName": "One",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "user1",
      "email": "user1@internship.com",
      "firstName": "User",
      "lastName": "One",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "user2",
      "email": "user2@internship.com",
      "firstName": "User",
      "lastName": "Two",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    }
  ]
}
