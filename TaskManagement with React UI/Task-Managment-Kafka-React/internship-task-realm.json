{
  "realm": "internship-task-realm",
  "enabled": true,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 1800,
  "roles": {
    "realm": [
      { "name": "ADMIN", "description": "Full access to all tasks" },
      { "name": "USER",  "description": "Access to own tasks only" }
    ]
  },

  "clients": [
    {
      "clientId": "task-frontend",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://task-frontend:3000/*"
      ],
      "webOrigins": ["http://localhost:3000", "http://task-frontend:3000"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "task-backend",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false
    }
  ],

  "users": [
    {
      "username": "admin1",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "admin123", "temporary": false}],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "user1",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "user123", "temporary": false}],
      "realmRoles": ["USER"]
    }
  ]
}
