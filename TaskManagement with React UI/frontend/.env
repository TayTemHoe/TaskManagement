# ==============================================
# Local development environment variables
# Vite embeds VITE_* vars at BUILD TIME into the JS bundle.
# These must use 'localhost' — the browser cannot resolve
# Docker container names like 'keycloak:8180'.
# ==============================================
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=internship-task-realm
VITE_KEYCLOAK_CLIENT_ID=task-frontend

# When running locally (npm run dev with Vite proxy):
# Use /api as the base URL — Vite proxies it to http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080
