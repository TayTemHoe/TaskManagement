{
  "info": {
    "name": "Task Management API — Spring Boot + Kafka + MongoDB",
    "description": "Complete API test collection for the Task Management System.\n\nArchitecture: Spring Boot 4 + Kafka + MongoDB (EDA + Reactive)\n\nFlow: POST/PUT/DELETE → Kafka topic → Consumer → MongoDB\nNote: Write operations return 202 Accepted (async). Wait 1-2 seconds before GET to confirm.\n\nBase URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "TASK-1001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 — CREATE",
      "item": [
        {
          "name": "Create Task — Valid (PENDING + HIGH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 202 Accepted', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "pm.test('Response contains Task ID', function () {",
                  "    pm.expect(pm.response.text()).to.include('Task ID:');",
                  "});",
                  "// Extract and save task ID for use in later requests",
                  "const body = pm.response.text();",
                  "const match = body.match(/Task ID: (TASK-[A-Z0-9-]+)/);",
                  "if (match) {",
                  "    pm.collectionVariables.set('taskId', match[1]);",
                  "    console.log('Saved taskId:', match[1]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Prepare internship report\",\n  \"description\": \"Complete weekly internship summary\",\n  \"status\": \"PENDING\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2026-06-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a new task. Returns 202 Accepted immediately — task is saved to MongoDB asynchronously after Kafka delivers the event.\n\nWait 1-2 seconds before calling GET to confirm the task was saved."
          }
        },
